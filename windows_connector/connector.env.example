# Copy this file to connector.env on the Windows POS computer.
POS_DBF_DIR=C:\path\to\ashpsdat
SHOPIFY_SYNC_BASE_URL=https://your-sync-app.example.com
SHOPIFY_SYNC_API_KEY=your_pos_key
SHOPIFY_SYNC_API_SECRET=your_pos_secret

SYNC_INTERVAL_SECONDS=180
# Run the complete POS quantity reconciliation once per local day at/after this hour (0 = midnight).
NIGHTLY_FULL_SYNC_HOUR=0
CONNECTOR_BATCH_SIZE=25
CONNECTOR_WORKERS=2
CONNECTOR_TIMEOUT_SECONDS=300

# The first successful run uploads product/SKU details. Later runs send inventory adjustments only.
INITIAL_CATALOG_UPLOAD=true

# Start with dry-run. Change to vfp-oledb only after testing against a copied DBF folder.
POS_WRITEBACK_MODE=dry-run

# Pull Shopify order webhooks from Railway into C:\ashpsdat\shopify-orders.db.
ORDER_SYNC_ENABLED=true
# Optional override; omit this line to store the database in POS_DBF_DIR.
SHOPIFY_ORDER_DB_PATH=C:\ashpsdat\shopify-orders.db
ORDER_DB_RETENTION_ROWS=250

# Local storage remains bounded: one state file, one backup, and rotating logs.
CONNECTOR_DATA_DIR=C:\ProgramData\ShopifyPosConnector
CONNECTOR_LOG_MAX_BYTES=5242880
CONNECTOR_LOG_BACKUPS=3
